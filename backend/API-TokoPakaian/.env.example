# ===========================================
# TOKO PAKAIAN API - default .env
# ===========================================

# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database Configuration (PostgreSQL / Supabase)
# Option 1: Individual parameters (for local/direct connectivity)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=toko_online
DB_PASSWORD=

# Option 2: Connection String (Recommended for Supabase PostgreSQL)
# Get this from Supabase Project Settings > Database > Connection String > URI
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ryicsaylvsvvuljommdj.supabase.co:5432/postgres

# Option 3: Supabase SDK Configuration
# Get these from Supabase Project Settings > API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT Configuration
JWT_ACCESS_SECRET=eyjafjalla
JWT_REFRESH_SECRET=eyjafjalla_the_hvít_aska
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Security Configuration
BCRYPT_SALT_ROUNDS=12

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 menit
RATE_LIMIT_MAX=100           # 100 request per window